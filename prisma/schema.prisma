datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  USER
  ADMIN
}

enum UserStatus {
  PENDING
  ACTIVE
  SUSPENDED
}

enum SubscriptionType {
  DEMO
  BASIC
  PREMIUM
  GOLD
}

model User {
  id                    String           @id @default(auto()) @map("_id") @db.ObjectId
  name                  String?
  email                 String?          @unique
  emailVerified         DateTime?
  verificationToken     String?
  image                 String?
  password              String?
  role                  Role             @default(USER)
  status                UserStatus       @default(PENDING)
  subscriptionType      SubscriptionType @default(DEMO)
  subscriptionExpiresAt DateTime?
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt

  products      Product[]
  clients       Client[]
  invoices      Invoice[]
  quotes        Quote[]
  company       Company?
  warehouses    Warehouse[]
}

model Company {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  name           String
  logo           String?
  email          String?
  phone          String?
  address        String?
  ice            String?  // Identifiant Commun de l'Entreprise
  rc             String?  // Registre du Commerce
  if             String?  // Identifiant Fiscal
  cn             String?  // Taxe Professionnelle / Autre
  cinNumber      String?  // N° de la CIN
  cinPathFront   String?  // Image path
  cinPathBack    String?  // Image path
  bankAccount    String?  // RIB
  userId         String   @unique @db.ObjectId
  user           User     @relation(fields: [userId], references: [id])
}

model Warehouse {
  id                String   @id @default(auto()) @map("_id") @db.ObjectId
  name              String
  address           String
  city              String
  contactName       String?
  contactEmail      String?
  contactPhone      String?
  allowedCategories String[] // Empty means all
  userId            String   @db.ObjectId
  user              User     @relation(fields: [userId], references: [id])
  movements         StockMovement[]
  stocks            WarehouseStock[]
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model WarehouseStock {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  productId   String   @db.ObjectId
  warehouseId String   @db.ObjectId
  quantity    Int      @default(0)
  product     Product  @relation(fields: [productId], references: [id])
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id])

  @@unique([productId, warehouseId])
}

model Product {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  reference       String   
  name            String
  brand           String?
  description     String?
  price           Float
  stock           Int      @default(0)
  lowStockAlert   Int      @default(5)
  category        String?
  images          String[]
  userId          String   @db.ObjectId
  user            User     @relation(fields: [userId], references: [id])
  movements       StockMovement[]
  warehouseStocks WarehouseStock[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([reference, userId])
}

model StockMovement {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  type        String   // IN, OUT
  quantity    Int
  note        String?
  productId   String   @db.ObjectId
  product     Product  @relation(fields: [productId], references: [id])
  warehouseId String?  @db.ObjectId
  warehouse   Warehouse? @relation(fields: [warehouseId], references: [id])
  userId      String   @db.ObjectId
  createdAt   DateTime @default(now())
}

model Client {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  name          String
  email         String?
  phone         String?
  address       String?
  isProspect    Boolean  @default(true)
  userId        String   @db.ObjectId
  user          User     @relation(fields: [userId], references: [id])
  interactions  Interaction[]
  invoices      Invoice[]
  quotes        Quote[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Interaction {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  date      DateTime @default(now())
  note      String
  clientId  String   @db.ObjectId
  client    Client   @relation(fields: [clientId], references: [id])
  userId    String   @db.ObjectId
  createdAt DateTime @default(now())
}

model Invoice {
  id               String   @id @default(auto()) @map("_id") @db.ObjectId
  number           String   
  date             DateTime @default(now())
  dueDate          DateTime
  status           String   @default("DRAFT") // DRAFT, SENT, PAID, OVERDUE, PARTIAL
  taxRate          Float    @default(20.0)
  discount         Float    @default(0.0)
  total            Float
  notes            String?
  clientId         String   @db.ObjectId
  client           Client   @relation(fields: [clientId], references: [id])
  userId           String   @db.ObjectId
  user             User     @relation(fields: [userId], references: [id])
  items            InvoiceItem[]
  payments         Payment[]
  stripeCustomerId String?
  paymentStatus    String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([number, userId])
}

model Quote {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  number      String   
  date        DateTime @default(now())
  validUntil  DateTime
  status      String   @default("DRAFT") // DRAFT, SENT, ACCEPTED, REJECTED, CONVERTED
  total       Float
  clientId    String   @db.ObjectId
  client      Client   @relation(fields: [clientId], references: [id])
  userId      String   @db.ObjectId
  user        User     @relation(fields: [userId], references: [id])
  items       QuoteItem[]
  isConverted Boolean  @default(false)
  invoiceId   String?  @db.ObjectId
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([number, userId])
}

model InvoiceItem {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  description String
  quantity    Int
  price       Float
  invoiceId   String   @db.ObjectId
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
}

model QuoteItem {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  description String
  quantity    Int
  price       Float
  quoteId     String   @db.ObjectId
  quote       Quote    @relation(fields: [quoteId], references: [id], onDelete: Cascade)
}

model Payment {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  amount    Float
  date      DateTime @default(now())
  method    String?
  invoiceId String   @db.ObjectId
  invoice   Invoice  @relation(fields: [invoiceId], references: [id])
}
