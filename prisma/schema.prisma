datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  USER
  ADMIN
  COMMERCIAL
  MAGASINIER
}

enum UserStatus {
  PENDING
  ACTIVE
  SUSPENDED
  ARCHIVED
}

enum SubscriptionType {
  DEMO
  BASIC
  PREMIUM
  GOLD
}

model User {
  id                    String           @id @default(auto()) @map("_id") @db.ObjectId
  name                  String?
  email                 String?          @unique
  emailVerified         DateTime?
  verificationToken     String?
  image                 String?
  password              String?
  role                  Role             @default(USER)
  status                UserStatus       @default(PENDING)
  subscriptionType      SubscriptionType @default(DEMO)
  subscriptionExpiresAt DateTime?

  phone    String?
  adminId  String? @db.ObjectId
  admin    User?   @relation("SubUsers", fields: [adminId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  subUsers User[]  @relation("SubUsers")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products   Product[]
  clients    Client[]
  suppliers  Supplier[]
  invoices   Invoice[]
  quotes     Quote[]
  company    Company?
  warehouses Warehouse[]
  cashTransactions CashTransaction[]
}

model Company {
  id           String  @id @default(auto()) @map("_id") @db.ObjectId
  name         String
  logo         String?
  email        String?
  phone        String?
  address      String?
  ice          String? // Identifiant Commun de l'Entreprise
  rc           String? // Registre du Commerce
  if           String? // Identifiant Fiscal
  cn           String? // Taxe Professionnelle / Autre
  cinNumber    String? // N° de la CIN
  cinPathFront String? // Image path
  cinPathBack  String? // Image path
  bankAccount  String? // RIB (old field, keeping for compatibility)

  // Nouveaux champs demandés par l'utilisateur
  pdfFooter        String?
  bankName         String?
  bankAddress      String?
  bankRib          String?
  bankSwift        String?
  bankContactName  String?
  bankContactPhone String?

  rolePermissions Json? // { COMMERCIAL: string[], MAGASINIER: string[] }
  userId          String        @unique @db.ObjectId
  user            User          @relation(fields: [userId], references: [id])
  bankAccounts    BankAccount[]
}

model BankAccount {
  id           String  @id @default(auto()) @map("_id") @db.ObjectId
  name         String? // Ex: "Compte Principal"
  bankName     String
  bankAddress  String?
  rib          String
  swift        String?
  contactName  String?
  contactPhone String?
  isMain       Boolean @default(false)

  companyId String  @db.ObjectId
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Warehouse {
  id                String           @id @default(auto()) @map("_id") @db.ObjectId
  name              String
  address           String
  city              String
  contactName       String?
  contactEmail      String?
  contactPhone      String?
  allowedCategories String[] // Empty means all
  userId            String           @db.ObjectId
  user              User             @relation(fields: [userId], references: [id])
  movements         StockMovement[]
  stocks            WarehouseStock[]
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
}

model WarehouseStock {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  productId   String    @db.ObjectId
  warehouseId String    @db.ObjectId
  quantity    Int       @default(0)
  product     Product   @relation(fields: [productId], references: [id])
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id])

  @@unique([productId, warehouseId])
}

model Product {
  id              String              @id @default(auto()) @map("_id") @db.ObjectId
  reference       String
  name            String
  brand           String?
  description     String?
  price           Float
  costPrice       Float? // Prix de revient (coût d'achat réel)
  taxRate         Float               @default(20.0)
  stock           Int                 @default(0)
  lowStockAlert   Int                 @default(5)
  category        String?
  images          String[]
  userId          String              @db.ObjectId
  user            User                @relation(fields: [userId], references: [id])
  movements       StockMovement[]
  warehouseStocks WarehouseStock[]
  purchaseItems   PurchaseOrderItem[]
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@unique([reference, userId])
}

model StockMovement {
  id          String     @id @default(auto()) @map("_id") @db.ObjectId
  type        String // IN, OUT
  quantity    Int
  note        String?
  productId   String     @db.ObjectId
  product     Product    @relation(fields: [productId], references: [id])
  warehouseId String?    @db.ObjectId
  warehouse   Warehouse? @relation(fields: [warehouseId], references: [id])
  userId      String     @db.ObjectId

  createdByName String?
  createdAt     DateTime @default(now())
}

enum ClientType {
  B2B
  B2C
}

enum PaymentMethod {
  CHEQUE
  LCN
  VIREMENT
  CASH
}

model Client {
  id   String     @id @default(auto()) @map("_id") @db.ObjectId
  type ClientType @default(B2C)
  name String // Raison sociale ou Nom complet

  // Tax IDs (Moroccan context)
  ice String? // Identifiant Commun de l'Entreprise
  if  String? // Identifiant Fiscal
  rc  String? // Registre du Commerce

  // Main Contact
  contactName     String?
  contactPosition String?
  email           String? // Primary email
  phone           String? // Primary phone (Mandatory according to user rules)

  // Logistics
  billingAddress  String?
  shippingAddress String?

  // Commercial
  paymentTerms    Int?           @default(0) // Delay in days (0 = at order)
  paymentMethod   PaymentMethod? @default(CASH)
  defaultDiscount Float?         @default(0.0)
  category        String? // e.g. Grossiste, Détaillant, VIP
  tags            String[]       @default([])

  // Risk Management
  creditLimit Float? @default(0.0)

  // Status
  isProspect           Boolean @default(true)
  isArchived           Boolean @default(false)
  autoRemindersEnabled Boolean @default(true)

  userId String @db.ObjectId
  user   User   @relation(fields: [userId], references: [id])

  invoices Invoice[]
  quotes   Quote[]

  createdByName String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  interactions  Interaction[]
  cashTransactions CashTransaction[]

  @@unique([email, userId])
  @@unique([ice, userId])
}

model Interaction {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  date          DateTime @default(now())
  note          String
  clientId      String   @db.ObjectId
  client        Client   @relation(fields: [clientId], references: [id])
  userId        String   @db.ObjectId
  createdByName String?
  createdAt     DateTime @default(now())
}

model Invoice {
  id               String         @id @default(auto()) @map("_id") @db.ObjectId
  number           String
  date             DateTime       @default(now())
  dueDate          DateTime
  status           String         @default("DRAFT") // DRAFT, SENT, PAID, OVERDUE, PARTIAL
  taxRate          Float          @default(20.0)
  discount         Float          @default(0.0)
  total            Float
  notes            String?
  quoteNumber      String? // Reference to origin quote
  poNumber         String? // Reference to Purchase Order (Bon de commande)
  attachments      String[] // For uploaded documents like cheque copies
  clientId         String         @db.ObjectId
  client           Client         @relation(fields: [clientId], references: [id])
  userId           String         @db.ObjectId
  user             User           @relation(fields: [userId], references: [id])
  items            InvoiceItem[]
  payments         Payment[]
  deliveryNotes    DeliveryNote[]
  stripeCustomerId String?
  paymentStatus    String?
  lastReminderAt   DateTime?
  reminderHistory  String[]       @default([])

  createdByName String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  cashTransactions CashTransaction[]

  @@unique([number, userId])
}

model DeliveryNote {
  id        String             @id @default(auto()) @map("_id") @db.ObjectId
  number    String
  date      DateTime           @default(now())
  invoiceId String             @db.ObjectId
  invoice   Invoice            @relation(fields: [invoiceId], references: [id])
  clientId  String             @db.ObjectId
  userId    String             @db.ObjectId
  items     DeliveryNoteItem[]
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  @@unique([number, userId])
}

model DeliveryNoteItem {
  id             String       @id @default(auto()) @map("_id") @db.ObjectId
  reference      String?
  description    String
  quantity       Int
  deliveryNoteId String       @db.ObjectId
  deliveryNote   DeliveryNote @relation(fields: [deliveryNoteId], references: [id], onDelete: Cascade)
}

model Quote {
  id          String      @id @default(auto()) @map("_id") @db.ObjectId
  number      String
  date        DateTime    @default(now())
  validUntil  DateTime
  status      String      @default("DRAFT") // DRAFT, SENT, ACCEPTED, REJECTED, CONVERTED
  taxRate     Float       @default(20.0)
  discount    Float       @default(0.0)
  total       Float
  notes       String?
  clientId    String      @db.ObjectId
  client      Client      @relation(fields: [clientId], references: [id])
  userId      String      @db.ObjectId
  user        User        @relation(fields: [userId], references: [id])
  items       QuoteItem[]
  isConverted Boolean     @default(false)
  invoiceId   String?     @db.ObjectId

  createdByName String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([number, userId])
}

model InvoiceItem {
  id          String  @id @default(auto()) @map("_id") @db.ObjectId
  reference   String?
  description String
  quantity    Int
  price       Float
  taxRate     Float   @default(20.0)
  invoiceId   String  @db.ObjectId
  invoice     Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
}

model QuoteItem {
  id          String  @id @default(auto()) @map("_id") @db.ObjectId
  reference   String?
  description String
  quantity    Int
  price       Float
  taxRate     Float   @default(20.0)
  quoteId     String  @db.ObjectId
  quote       Quote   @relation(fields: [quoteId], references: [id], onDelete: Cascade)
}

model Payment {
  id        String    @id @default(auto()) @map("_id") @db.ObjectId
  amount    Float
  date      DateTime  @default(now())
  method    String? // CASH, CHEQUE, TRANSFER, LCN
  reference String? // Numéro de chèque, LCN, ou virement
  dueDate   DateTime? // Date d'encaissement pour Chèque/LCN
  notes     String?
  type      String    @default("IN") // IN = Recette Client, OUT = Dépense Fournisseur
  status    String    @default("COMPLETED") // COMPLETED, PENDING (Ex: À payer)

  invoiceId String?  @db.ObjectId
  invoice   Invoice? @relation(fields: [invoiceId], references: [id])

  purchaseOrderId String?        @db.ObjectId
  purchaseOrder   PurchaseOrder? @relation(fields: [purchaseOrderId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Supplier {
  id             String          @id @default(auto()) @map("_id") @db.ObjectId
  name           String
  contactName    String?
  email          String?
  phone          String?
  address        String?
  ice            String?
  userId         String          @db.ObjectId
  user           User            @relation(fields: [userId], references: [id])
  purchaseOrders PurchaseOrder[]

  createdByName String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  cashTransactions CashTransaction[]
}

model PurchaseOrder {
  id              String    @id @default(auto()) @map("_id") @db.ObjectId
  number          String
  date            DateTime  @default(now())
  expectedDate    DateTime?
  status          String    @default("DRAFT") // DRAFT, ORDERED, PARTIAL, RECEIVED, INVOICED, CLOSED
  additionalCosts Float     @default(0.0) // Frais d'approche (Landed cost)
  invoiceNumber   String? // Numéro de la facture fournisseur
  invoiceTotal    Float? // Total réel figurant sur la facture fournisseur
  notes           String?

  supplierId String   @db.ObjectId
  supplier   Supplier @relation(fields: [supplierId], references: [id])
  userId     String   @db.ObjectId

  items    PurchaseOrderItem[]
  payments Payment[]

  createdByName String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  cashTransactions CashTransaction[]

  @@unique([number, userId])
}

model PurchaseOrderItem {
  id               String @id @default(auto()) @map("_id") @db.ObjectId
  quantity         Int // Quantité commandée en unité de mesure
  receivedQuantity Int    @default(0) // Quantité reçue réelle
  unitOfMeasure    String @default("UNITE") // Ex: Carton, Palette, Pièce
  conversionFactor Float  @default(1.0) // Ex: 1 Carton = 12 Unités en stock (Stock de vente)
  unitPrice        Float // Prix unitaire commandé (en UoM)
  invoicePrice     Float? // Prix facturé réel (pour vérification vs unitPrice)

  productId String  @db.ObjectId
  product   Product @relation(fields: [productId], references: [id])

  purchaseOrderId String        @db.ObjectId
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
}

enum CashTransactionType {
  IN
  OUT
}

enum CashTransactionStatus {
  PENDING   // e.g. en coffre / en attente
  DEPOSITED // e.g. déposé à la banque
  COMPLETED // e.g. encaissé / exécuté
  CANCELLED // e.g. rejeté / annulé
}

model CashTransaction {
  id              String                @id @default(auto()) @map("_id") @db.ObjectId
  type            CashTransactionType   // IN, OUT
  amount          Float
  transactionDate DateTime              @default(now()) // Date de saisie / d'émission
  realDate        DateTime?             // Date d'encaissement effective (pour prévisionnel)
  paymentMethod   PaymentMethod         @default(CASH)
  status          CashTransactionStatus @default(COMPLETED)
  category        String?               // Ex: Loyer, Salaire, Electricite, Transfert, Client, Fournisseur
  description     String?
  reference       String?               // Numéro de chèque / LCN / Virement
  
  clientId        String?               @db.ObjectId
  client          Client?               @relation(fields: [clientId], references: [id])
  supplierId      String?               @db.ObjectId
  supplier        Supplier?             @relation(fields: [supplierId], references: [id])
  invoiceId       String?               @db.ObjectId
  invoice         Invoice?              @relation(fields: [invoiceId], references: [id])
  purchaseOrderId String?               @db.ObjectId
  purchaseOrder   PurchaseOrder?        @relation(fields: [purchaseOrderId], references: [id])
  
  userId          String                @db.ObjectId
  user            User                  @relation(fields: [userId], references: [id])

  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
}
